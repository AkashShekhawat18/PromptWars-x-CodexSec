# Database & Cache Configurations
DATABASE_URL="postgresql://postgres:password@localhost:5432/neuroflow_db?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=5000

# Security Credentials
JWT_SECRET="supersecret_jwt_sign_key_should_be_long_and_random"
JWT_REFRESH_SECRET="supersecret_jwt_refresh_sign_key_should_be_long_and_random"

# Third-Party Integrations
GOOGLE_CLIENT_ID="google_client_id_placeholder.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="google_client_secret_placeholder"

# Object Storage / File Management
CLOUDINARY_CLOUD_NAME="cloudinary_cloud_name_placeholder"
CLOUDINARY_API_KEY="cloudinary_api_key_placeholder"
CLOUDINARY_API_SECRET="cloudinary_api_secret_placeholder"

# AI Service Engine
GEMINI_API_KEY="" # Keep empty as requested; user will configure this
